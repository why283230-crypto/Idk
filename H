-- Dropdown เลือกบอส 3 ตัวตามโฟลเดอร์จริง
MainTab:Dropdown({
    Title     = "เลือกบอสที่ต้องการตี",
    Desc      = "จะแสกนไปที่ workspace.ClientEntities",
    Icon      = "list",
    Values    = { "Great Ape", "Armored Titan", "Crocodile" },
    Value     = "Great Ape",
    Callback  = function(selected)
        selectedBoss = selected
        -- ถ้าเปิดฟาร์มอยู่แล้วให้เริ่มทำงานใหม่ทันทีที่เปลี่ยนบอส
        if farmingEnabled then
            startFarm()
        end
    end,
})

MainTab:Divider()

-- ปุ่มเปิด/ปิดการวาร์ป
MainTab:Toggle({
    Title = "Auto Farm Boss",
    Desc  = "เปิดระบบวาร์ปไปล็อกตัวบอสที่เลือกไว้",
    Icon  = "zap",
    Value = false,
    Callback = function(state)
        if state then
            if selectedBoss then
                startFarm()
                WindUI:Notify({ Title = "เปิดฟาร์มสำเร็จ", Content = "กำลังวาร์ปไปหา " .. selectedBoss, Duration = 3, Icon = "play" })
            else
                WindUI:Notify({ Title = "ข้อผิดพลาด", Content = "กรุณาเลือกบอสก่อนเปิดใช้งาน", Duration = 3, Icon = "alert-circle" })
            end
        else
            stopFarm()
            WindUI:Notify({ Title = "ปิดฟาร์มสำเร็จ", Duration = 2, Icon = "square" })
        end
    end,
})

