-- ========================
-- Maps & Configurations
-- ========================
local bossPaths = {
    ["Great Ape"]     = "GreatApe",
    ["Armored Titan"] = "ArmoredTitan",
    ["Crocodile"]     = "Crocodile",
}

local slotKeyCode = {
    [1] = Enum.KeyCode.One,
    [2] = Enum.KeyCode.Two,
    [3] = Enum.KeyCode.Three,
    [4] = Enum.KeyCode.Four,
    [5] = Enum.KeyCode.Five,
}

-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.02)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

-- ฟังก์ชันหาตำแหน่งบอสใน ClientEntities 
local function getBossPosition(bossName)
    local folderName = bossPaths[bossName]
    if not folderName then return nil end

    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if not clientEntities then return nil end

    local bossModel = clientEntities:FindFirstChild(folderName)
    if not bossModel then return nil end

    local root = bossModel:FindFirstChild("HumanoidRootPart") 
        or bossModel:FindFirstChild("RootPart") 
        or bossModel.PrimaryPart

    if not root then
        for _, part in ipairs(bossModel:GetDescendants()) do
            if part:IsA("BasePart") then
                root = part
                break
            end
        end
    end

    return root and root.Position
end

-- ระบบตรวจจับสถานะสล็อตไอเทมตามรูปภาพจริง (เช็คขอบขาว UIStroke / พื้นหลังทำงาน)
local function isSlotEquipped()
    local equipped = false
    pcall(function()
        local playerGui = LocalPlayer:WaitForChild("PlayerGui", 3)
        if not playerGui then return end

        -- สแกนหา Hotbar UI ในลักษณะยืดหยุ่นดักจับทุกโครงสร้างเกม
        local hotbar = playerGui:FindFirstChild("Hotbar", true) 
            or (playerGui:FindFirstChild("Main", true) and playerGui.Main:FindFirstChild("HUD", true) and playerGui.Main.HUD:FindFirstChild("Hotbar"))

        if hotbar then
            local targetSlotStr = tostring(selectedSlot)
            for _, child in ipairs(hotbar:GetDescendants()) do
                -- ค้นหาออบเจกต์ข้อความที่เป็นตัวเลขของสล็อตที่ต้องการตรวจ
                if child:IsA("TextLabel") and (child.Text == targetSlotStr or child.Name == targetSlotStr) then
                    local slotFrame = child.Parent
                    if slotFrame then
                        -- 1. ตรวจสอบ UIStroke กรอบสีขาวสว่างตามในภาพหลักฐานชิ้นที่ 1
                        local stroke = slotFrame:FindFirstChildOfClass("UIStroke") or child:FindFirstChildOfClass("UIStroke")
                        if stroke and stroke.Enabled and stroke.Thickness > 0 then
                            equipped = true
                            return
                        end
                        -- 2. ตรวจสอบความทึบแสงของพื้นหลัง (ถ้ากดเลือกแล้วพื้นหลังจะเปลี่ยนค่าโปร่งใส)
                        if slotFrame:IsA("GuiObject") and slotFrame.BackgroundTransparency < 0.5 then
                            equipped = true
                            return
                        end
                    end
                end
            end
        end
    end)

    -- ระบบตรวจจับสำรองกรณี UI ตัวเกมโหลดไม่ทัน
    if not equipped then
        local char = LocalPlayer.Character
        if char then
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Tool") then
                    equipped = true
                    break
                end
            end
        end
    end

    return equipped
end

-- ========================
-- Farm Logic (วนลูปตามบอสที่เลือกทั้งหมด)
-- ========================
local function stopFarm()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarm()
    stopFarm()
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local hasTarget = false
            
            -- วนลูปสแกนบอสทุกตัวที่ถูกเลือกไว้ในลิสต์พร้อมกัน
            for bossName, enabled in pairs(selectedBosses) do
                if not enabled then continue end
                
                local hrp = getHRP()
                local bossPos = getBossPosition(bossName)

                if hrp and bossPos then
                    hrp.CFrame = CFrame.new(bossPos)
                    hasTarget = true
                    task.wait(0.2) -- หน่วงเวลาสั้นๆ ระหว่างตีบอสตัวนั้น
                end
            end
            
            -- [NEW LOGIC] หากเปิดระบบ Auto Boss อยู่แต่หาบอสไม่เจอ และเปิดสวิตช์ Save Pos ไว้ จะวาร์ปกลับจุดเซฟ
            if not hasTarget then
                if useSavePosEnabled and savedPosition then
                    local hrp = getHRP()
                    if hrp then
                        hrp.CFrame = CFrame.new(savedPosition)
                    end
                end
                task.wait(0.3) -- ถ้าบอสทุกตัวที่เลือกยังไม่เกิดให้รอรอบถัดไป
            end
        end
    end)
end

-- ========================
-- Auto Equip Logic
-- ========================
local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedSlot then return end
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            -- หากระบบตรวจจับแล้วว่ายังไม่ได้ถือไอเทมชิ้นนั้น (ขอบหรือพื้นหลังยังไม่เปลี่ยน) จะทำการกดให้
            if not isSlotEquipped() then
                local kc = slotKeyCode[selectedSlot]
                if kc then
                    pressKey(kc)
                    task.wait(0.3) -- ดีเลย์รอการตอบสนองจากเซิร์ฟเวอร์เกม
                end
            else
                task.wait(0.4) -- ถือของชิ้นนั้นเสร็จสมบูรณ์แล้ว ให้สแตนด์บายตรวจเช็คอย่างเดียว ไม่กดรัวซ้ำเด็ดขาด
            end
        end
    end)
end

