local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- ========================
-- Services
-- ========================
local Players             = game:GetService("Players")
local UserInputService    = game:GetService("UserInputService")
local LocalPlayer         = Players.LocalPlayer

-- ========================
-- State
-- ========================
local farmingEnabled = false
local farmThread     = nil
local selectedBoss   = nil -- เลือกบอสทีละตัวเพื่อความแม่นยำในการฟาร์ม
local uiVisible      = true

-- ========================
-- Boss Configuration
-- ========================
local bossPaths = {
    ["Great Ape"]     = "GreatApe",
    ["Armored Titan"] = "ArmoredTitan",
    ["Crocodile"]     = "Crocodile",
}

-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- ฟังก์ชันหาตำแหน่งบอสใน ClientEntities ตรงๆ ตามที่คุณระบุ
local function getBossPosition(bossName)
    local folderName = bossPaths[bossName]
    if not folderName then return nil end

    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if not clientEntities then return nil end

    local bossModel = clientEntities:FindFirstChild(folderName)
    if not bossModel then return nil end

    -- หาพิกัดจากชิ้นส่วนในตัวบอส
    local root = bossModel:FindFirstChild("HumanoidRootPart") 
        or bossModel:FindFirstChild("RootPart") 
        or bossModel.PrimaryPart

    if not root then
        for _, part in ipairs(bossModel:GetDescendants()) do
            if part:IsA("BasePart") then
                root = part
                break
            end
        end
    end

    return root and root.Position
end

-- ========================
-- Farm Logic
-- ========================
local function stopFarm()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarm()
    stopFarm()
    if not selectedBoss then return end
    
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local hrp = getHRP()
            local bossPos = getBossPosition(selectedBoss)

            if hrp and bossPos then
                -- วาร์ปไปพิกัดบอสโดยตรง
                hrp.CFrame = CFrame.new(bossPos)
            end
            task.wait(0.2) -- ความเร็วในการตรวจสอบและวาร์ปซ้ำ
        end
    end)
end

