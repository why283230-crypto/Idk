-- -- MonHub | Farm Boss Simple Edition (Toggle Loop Edition)
-- -- Wind UI Latest
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- ========================
-- Services
-- ========================
local Players             = game:GetService("Players")
local UserInputService    = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager") 
local LocalPlayer         = Players.LocalPlayer

-- ========================
-- State
-- ========================
local farmingEnabled = false
local farmThread     = nil

local targetBosses = {
    ["Great Ape"]     = false,
    ["Armored Titan"] = false,
    ["Crocodile"]     = false
}

local savedPosition     = nil
local useSavePosEnabled = false 

local autoEquipEnabled = false
local autoEquipThread  = nil
local selectedSlot     = 1 

-- ========================
-- Boss Configuration
-- ========================
local bossPaths = {
    ["Great Ape"]     = "GreatApe",
    ["Armored Titan"] = "ArmoredTitan",
    ["Crocodile"]     = "Crocodile",
}

local slotKeyCode = {
    [1] = Enum.KeyCode.One, [2] = Enum.KeyCode.Two, [3] = Enum.KeyCode.Three, [4] = Enum.KeyCode.Four, [5] = Enum.KeyCode.Five,
}

local hotbarSlotNames = { "Strength", "Sword", "Durability", "Chakra" }

-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true,  keyCode, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

local function getBossPosition(bossName)
    local folderName = bossPaths[bossName]
    if not folderName then return nil end
    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if not clientEntities then return nil end
    local bossModel = clientEntities:FindFirstChild(folderName)
    if not bossModel then return nil end
    local root = bossModel:FindFirstChild("HumanoidRootPart") or bossModel:FindFirstChild("RootPart") or bossModel.PrimaryPart
    return root and root.Position
end

local function isSlotEquipped()
    local success, result = pcall(function()
        local hud = LocalPlayer.PlayerGui:FindFirstChild("Main") and LocalPlayer.PlayerGui.Main:FindFirstChild("HUD") and LocalPlayer.PlayerGui.Main.HUD:FindFirstChild("Hotbar")
        if not hud then return false end
        for _, slotName in ipairs(hotbarSlotNames) do
            local slot = hud:FindFirstChild(slotName)
            if slot then
                local selectedFrame = slot:FindFirstChild("Selected") or slot:FindFirstChild("Active") or slot:FindFirstChild("Equipped")
                if selectedFrame and selectedFrame.Visible then return true end
            end
        end
        return false
    end)
    return success and result
end

-- ========================
-- Logic Systems
-- ========================
local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then task.cancel(autoEquipThread) autoEquipThread = nil end
end

local function startAutoEquip()
    stopAutoEquip()
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            if not isSlotEquipped() then pressKey(slotKeyCode[selectedSlot]) end
            task.wait(0.5)
        end
    end)
end

local function updateFarmState()
    local anyBossEnabled = false
    for _, enabled in pairs(targetBosses) do if enabled then anyBossEnabled = true break end end
    if not anyBossEnabled then farmingEnabled = false if farmThread then task.cancel(farmThread) farmThread = nil end return end
    if farmingEnabled then return end
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local hasTarget = false
            for bossName, enabled in pairs(targetBosses) do
                if enabled then
                    local hrp, bossPos = getHRP(), getBossPosition(bossName)
                    if hrp and bossPos then hrp.CFrame = CFrame.new(bossPos) hasTarget = true task.wait(0.2) end
                end
            end
            if not hasTarget and useSavePosEnabled and savedPosition then
                local hrp = getHRP()
                if hrp then hrp.CFrame = CFrame.new(savedPosition) end
            end
            task.wait(0.1)
        end
    end)
end

-- ========================
-- Window Setup
-- ========================
local Window = WindUI:CreateWindow({
    Title = "MonHub | Simple Farm", Icon = "swords", Folder = "MonHubSimple",
    Size = UDim2.fromOffset(450, 520), Theme = "Dark", Acrylic = true, Transparent = true
})

local MainTab = Window:Tab({ Title = "Main Farm", Icon = "crosshair" })

for bossName, _ in pairs(targetBosses) do
    MainTab:Toggle({
        Title = "Auto "..bossName, Desc = "วาร์ปฟาร์ม "..bossName.." อัตโนมัติ", Icon = "zap",
        Callback = function(state) targetBosses[bossName] = state updateFarmState() end
    })
end

MainTab:Divider()
MainTab:Button({
    Title = "Save Position", Icon = "map-pin",
    Callback = function() local hrp = getHRP() if hrp then savedPosition = hrp.Position end end
})
MainTab:Toggle({
    Title = "Use Save Position", Icon = "refresh-cw",
    Callback = function(state) useSavePosEnabled = state end
})

