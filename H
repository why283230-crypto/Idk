-- ========================
-- Configurations & Maps
-- ========================
local bossModelKey = {
    ["Crocodile"]     = "Crocodile",
    ["Armored Titan"] = "ArmoredTitan",
    ["Great Ape"]     = "GreatApe",
}

local slotKeyCode = {
    [1] = Enum.KeyCode.One,
    [2] = Enum.KeyCode.Two,
    [3] = Enum.KeyCode.Three,
    [4] = Enum.KeyCode.Four,
    [5] = Enum.KeyCode.Five,
}

local letterKeyCode = {
    A = Enum.KeyCode.A, B = Enum.KeyCode.B, C = Enum.KeyCode.C,
    D = Enum.KeyCode.D, E = Enum.KeyCode.E, F = Enum.KeyCode.F,
    G = Enum.KeyCode.G, H = Enum.KeyCode.H, I = Enum.KeyCode.I,
    J = Enum.KeyCode.J, K = Enum.KeyCode.L, M = Enum.KeyCode.M,
    N = Enum.KeyCode.N, O = Enum.KeyCode.O, P = Enum.KeyCode.P,
    Q = Enum.KeyCode.Q, R = Enum.KeyCode.R, S = Enum.KeyCode.S,
    T = Enum.KeyCode.T, U = Enum.KeyCode.U, V = Enum.KeyCode.V,
    W = Enum.KeyCode.W, X = Enum.KeyCode.X, Y = Enum.KeyCode.Y,
    Z = Enum.KeyCode.Z,
}

local hotbarSlotNames = { "Strength", "Sword", "Durability", "Chakra" }

-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(pos)
    local hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(pos)
    end
end

local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

local function findBossPosition(bossName)
    local key = bossModelKey[bossName]
    if not key then return nil end

    local ce = workspace:FindFirstChild("ClientEntities")
    if not ce then return nil end

    local model = ce:FindFirstChild(key)
    if not model then return nil end

    local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("RootPart")

    if not root then
        for _, part in ipairs(model:GetDescendants()) do
            if part:IsA("BasePart") then
                root = part
                break
            end
        end
    end

    return root and root.Position
end

-- ========================
-- Auto Equip Logic (ศึกษาและแกะโครงสร้างตามโค้ดอ้างอิง)
-- ========================
local function isSlotEquipped()
    local success, result = pcall(function()
        local playerGui = LocalPlayer:WaitForChild("PlayerGui", 3)
        if not playerGui then return false end

        local main = playerGui:FindFirstChild("Main")
        if not main then return false end

        local hud = main:FindFirstChild("HUD")
        if not hud then return false end

        local hotbar = hud:FindFirstChild("Hotbar")
        if not hotbar then return false end

        for _, slotName in ipairs(hotbarSlotNames) do
            local slot = hotbar:FindFirstChild(slotName)
            if slot then
                local selectedFrame = slot:FindFirstChild("Selected")
                    or slot:FindFirstChild("Active")
                    or slot:FindFirstChild("Equipped")
                if selectedFrame and selectedFrame.Visible then
                    return true
                end
                if slot:IsA("GuiObject") then
                    local bg = slot.BackgroundTransparency
                    if bg ~= nil and bg < 0.9 then
                        return true
                    end
                end
            end
        end
        return false
    end)
    
    if success then return result end

    local char = LocalPlayer.Character
    if char then
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Tool") then return true end
        end
    end
    return false
end

local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedSlot then return end
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            if not isSlotEquipped() then
                local kc = slotKeyCode[selectedSlot]
                if kc then
                    pressKey(kc)
                    task.wait(0.5)
                end
            else
                task.wait(0.5)
            end
        end
    end)
end

-- ========================
-- Farm Logic
-- ========================
local function stopFarm()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarm()
    stopFarm()
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local found = false

            for bossName, enabled in pairs(selectedBosses) do
                if not enabled then continue end

                local pos = findBossPosition(bossName)
                if pos then
                    teleportTo(pos)
                    found = true
                    task.wait(0.3)
                else
                    task.wait(0.1)
                end
            end

            if not found then
                if useSavePosEnabled and savedPosition then
                    teleportTo(savedPosition)
                end
            end

            task.wait(0.5)
        end
    end)
end

-- ========================
-- Auto Skill Logic
-- ========================
local function stopAutoSkill()
    autoSkillEnabled = false
    if autoSkillThread then
        task.cancel(autoSkillThread)
        autoSkillThread = nil
    end
end

local function startAutoSkill()
    stopAutoSkill()
    autoSkillEnabled = true
    autoSkillThread = task.spawn(function()
        while autoSkillEnabled do
            local hasKey = false
            for letter, active in pairs(selectedSkillKeys) do
                if not active then continue end
                local kc = letterKeyCode[letter]
                if kc then
                    pcall(function()
                        VirtualInputManager:SendKeyEvent(true, kc, false, game)
                    end)
                    task.wait(0.05)
                    pcall(function()
                        VirtualInputManager:SendKeyEvent(false, kc, false, game)
                    end)
                    hasKey = true
                    task.wait(0.05)
                end
            end
            if not hasKey then
                task.wait(0.1)
            end
        end
    end)
end

