local LocalPlayer         = Players.LocalPlayer

-- ========================
-- State
-- ========================
local farmingEnabled   = false
local farmThread       = nil
local selectedBosses   = {} -- รองรับการเก็บรายชื่อบอสหลายตัว

-- [NEW STATE] ระบบบันทึกตำแหน่งพิกัดกลับ
local savedPosition     = nil
