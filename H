-- MonHub | Farm Boss Simple Edition (Multi-Boss & Auto Equip & Save Position)
-- Wind UI Latest
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- ========================
-- Services
-- ========================
local Players             = game:GetService("Players")
local UserInputService    = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer         = Players.LocalPlayer

-- ========================
-- State
-- ========================
local farmingEnabled   = false
local farmThread       = nil
local selectedBosses   = {} 

local savedPosition     = nil
local useSavePosEnabled = false 

-- [AUTO EQUIP STATE]
local autoEquipEnabled = false
local autoEquipThread  = nil
local selectedSlot     = 1  
local uiVisible        = true

-- ========================
-- Maps & Configurations
-- ========================
local bossPaths = {
    ["Great Ape"]     = "GreatApe",
    ["Armored Titan"] = "ArmoredTitan",
    ["Crocodile"]     = "Crocodile",
}

local slotKeyCode = {
    [1] = Enum.KeyCode.One, [2] = Enum.KeyCode.Two, [3] = Enum.KeyCode.Three,
    [4] = Enum.KeyCode.Four, [5] = Enum.KeyCode.Five,
}

-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.02)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

-- [AUTO EQUIP LOGIC]
local function isSlotEquipped()
    local equipped = false
    pcall(function()
        local playerGui = LocalPlayer:WaitForChild("PlayerGui", 3)
        local hotbar = playerGui:FindFirstChild("Hotbar", true) 
            or (playerGui:FindFirstChild("Main", true) and playerGui.Main:FindFirstChild("HUD", true) and playerGui.Main.HUD:FindFirstChild("Hotbar"))
        if hotbar then
            local targetSlotStr = tostring(selectedSlot)
            for _, child in ipairs(hotbar:GetDescendants()) do
                if child:IsA("TextLabel") and (child.Text == targetSlotStr or child.Name == targetSlotStr) then
                    local slotFrame = child.Parent
                    if slotFrame then
                        local stroke = slotFrame:FindFirstChildOfClass("UIStroke") or child:FindFirstChildOfClass("UIStroke")
                        if stroke and stroke.Enabled and stroke.Thickness > 0 then equipped = true; return end
                        if slotFrame:IsA("GuiObject") and slotFrame.BackgroundTransparency < 0.5 then equipped = true; return end
                    end
                end
            end
        end
    end)
    return equipped
end

local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then task.cancel(autoEquipThread); autoEquipThread = nil end
end

local function startAutoEquip()
    stopAutoEquip()
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            if not isSlotEquipped() then
                local kc = slotKeyCode[selectedSlot]
                if kc then pressKey(kc); task.wait(0.3) end
            end
            task.wait(0.4)
        end
    end)
end

-- ========================
-- Farm Logic & Setup
-- ========================
local function getBossPosition(bossName)
    local folderName = bossPaths[bossName]
    if not folderName then return nil end
    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if not clientEntities then return nil end
    local bossModel = clientEntities:FindFirstChild(folderName)
    if not bossModel then return nil end
    local root = bossModel:FindFirstChild("HumanoidRootPart") or bossModel:FindFirstChild("RootPart") or bossModel.PrimaryPart
    return root and root.Position
end

local function stopFarm()
    farmingEnabled = false
    if farmThread then task.cancel(farmThread); farmThread = nil end
end

local function startFarm()
    stopFarm()
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local hasTarget = false
            for bossName, enabled in pairs(selectedBosses) do
                if not enabled then continue end
                local hrp = getHRP(); local bossPos = getBossPosition(bossName)
                if hrp and bossPos then hrp.CFrame = CFrame.new(bossPos); hasTarget = true; task.wait(0.2) end
            end
            if not hasTarget and useSavePosEnabled and savedPosition then
                local hrp = getHRP()
                if hrp then hrp.CFrame = CFrame.new(savedPosition) end
                task.wait(0.3)
            end
        end
    end)
end

local Window = WindUI:CreateWindow({
    Title = "MonHub | Advanced Farm", Icon = "swords", Author = "MonHub", Folder = "MonHubAdvanced",
    Size = UDim2.fromOffset(480, 500), Theme = "Dark", ToggleKey = Enum.KeyCode.RightControl,
})

local MainTab = Window:Tab({ Title = "Main System", Icon = "crosshair" })

MainTab:Dropdown({
    Title = "เลือกบอสที่ต้องการตี", Values = { "Great Ape", "Armored Titan", "Crocodile" }, Multi = true,
    Callback = function(selected) selectedBosses = selected; if farmingEnabled then startFarm() end end
})

MainTab:Toggle({
    Title = "Auto Farm Boss", Callback = function(state) if state then startFarm() else stopFarm() end end
})

MainTab:Button({ Title = "Save Position", Callback = function() local hrp = getHRP(); if hrp then savedPosition = hrp.Position end end })

MainTab:Toggle({ Title = "Use Save Position", Callback = function(state) useSavePosEnabled = state end })

MainTab:Divider()

-- [UI AUTO EQUIP]
MainTab:Dropdown({
    Title = "Select Slot Auto Equip", Values = { "Slot 1", "Slot 2", "Slot 3", "Slot 4", "Slot 5" },
    Callback = function(v) selectedSlot = tonumber(v:match("%d")) or 1 end
})

MainTab:Toggle({
    Title = "Auto Equip Item", Callback = function(state) if state then startAutoEquip() else stopAutoEquip() end end
})

-- ========================
-- Floating UI (ทำงานตอนยุบหน้าจอ)
-- ========================
local FloatingGui = Instance.new("ScreenGui", (game:GetService("CoreGui") or LocalPlayer:WaitForChild("PlayerGui")))
local FloatingButton = Instance.new("TextButton", FloatingGui)
FloatingButton.Size = UDim2.fromOffset(50, 50); FloatingButton.Position = UDim2.new(0.05, 0, 0.2, 0)
FloatingButton.Text = "M"; FloatingButton.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
FloatingButton.Visible = false; FloatingButton.Draggable = true
Instance.new("UICorner", FloatingButton)

UserInputService.InputBegan:Connect(function(input, gp)
    if not gp and input.KeyCode == Enum.KeyCode.RightControl then
        uiVisible = not uiVisible
        FloatingButton.Visible = not uiVisible
    end
end)

FloatingButton.MouseButton1Click:Connect(function()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game)
    task.wait(0.01)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
    FloatingButton.Visible = false
end)
