-- ปรับปรุง: เปลี่ยนเป็น Dropdown แบบ Multi สามารถติ๊กเลือกได้หลายตัวพร้อมกัน
MainTab:Dropdown({
    Title     = "เลือกบอสที่ต้องการตี (เลือกได้หลายตัว)",
    Desc      = "จะแสกนไปที่ workspace.ClientEntities",
    Icon      = "list",
    Values    = { "Great Ape", "Armored Titan", "Crocodile" },
    Multi     = true,
    AllowNone = true,
    Callback  = function(selected)
        selectedBosses = selected
        -- ถ้าเปิดฟาร์มอยู่แล้วให้เริ่มทำงานใหม่ทันทีที่เปลี่ยนการเลือกบอส
        if farmingEnabled then
            startFarm()
        end
    end,
})

MainTab:Toggle({
    Title = "Auto Farm Boss",
    Desc  = "เปิดระบบวาร์ปไปล็อกตัวบอสที่เลือกไว้ทั้งหมดแบบวนลูป",
    Icon  = "zap",
    Value = false,
    Callback = function(state)
        if state then
            startFarm()
            WindUI:Notify({ Title = "เปิดฟาร์มสำเร็จ", Content = "กำลังเริ่มระบบฟาร์มบอสแบบวนลูป", Duration = 3, Icon = "play" })
        else
            stopFarm()
            WindUI:Notify({ Title = "ปิดฟาร์มสำเร็จ", Duration = 2, Icon = "square" })
        end
    end,
})

MainTab:Divider()

-- [เพิ่มใหม่] ระบบ Save Position แบบเปิด/ปิดอิสระตามเงื่อนไขที่คุณระบุ
MainTab:Button({
    Title = "Save Position (กดเพื่อเซฟจุดปัจจุบัน)",
    Desc  = "บันทึกพิกัดยืนปัจจุบันของคุณ เพื่อให้ตัวละครวาร์ปกลับมาเมื่อบอสไม่เกิด",
    Icon  = "map-pin",
    Callback = function()
        local hrp = getHRP()
        if hrp then
            savedPosition = hrp.Position
            WindUI:Notify({
                Title    = "บันทึกพิกัดสำเร็จ",
                Content  = ("X: %.1f | Y: %.1f | Z: %.1f"):format(savedPosition.X, savedPosition.Y, savedPosition.Z),
                Duration = 4,
                Icon     = "map-pin"
            })
        else
            WindUI:Notify({ Title = "เกิดข้อผิดพลาด", Content = "ไม่พบพิกัดตัวละครของคุณ", Duration = 3, Icon = "alert-circle" })
        end
    end,
})

MainTab:Toggle({
    Title = "Use Save Position (วาร์ปกลับเมื่อบอสไม่เกิด)",
    Desc  = "เดินได้ปกติเมื่อเปิดแค่อันเดียว ระบบจะดึงตัวกลับก็ต่อเมื่อเปิดฟาร์มแล้วไม่เจอบอส",
    Icon  = "refresh-cw",
    Value = false,
    Callback = function(state)
        useSavePosEnabled = state
        if state then
            if not savedPosition then
                WindUI:Notify({ Title = "คำเตือน", Content = "คุณยังไม่ได้กดเซฟพิกัด กรุณากด Save Position ก่อน", Duration = 4, Icon = "alert-circle" })
            else
                WindUI:Notify({ Title = "เปิดใช้งานระบบจุดเซฟเรียบร้อย", Duration = 2, Icon = "check" })
            end
        else
            WindUI:Notify({ Title = "ปิดใช้งานระบบจุดเซฟเรียบร้อย", Duration = 2, Icon = "x" })
        end
    end,
})

