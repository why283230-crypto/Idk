    ["Great Ape"]     = false,
    ["Armored Titan"] = false,
    ["Crocodile"]     = false
}

-- [STATE เพิ่มเติม] ระบบบันทึกตำแหน่งพิกัดกลับอัจฉริยะแบบแยกอิสระ
