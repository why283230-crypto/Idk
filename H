FloatingButton.Size = UDim2.fromOffset(50, 50)
FloatingButton.Position = UDim2.new(0.05, 0, 0.2, 0)
FloatingButton.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
FloatingButton.Text = "M"
FloatingButton.TextColor3 = Color3.fromRGB(255, 255, 255)
FloatingButton.Draggable = true
Instance.new("UICorner", FloatingButton).CornerRadius = UDim.new(0, 10)

FloatingButton.MouseButton1Click:Connect(function()
