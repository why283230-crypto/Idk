local LocalPlayer         = Players.LocalPlayer

-- ========================
-- State
-- ========================
local farmingEnabled = false
local farmThread     = nil
local selectedBosses = {} -- ปรับปรุง: รองรับการเก็บรายชื่อบอสหลายตัวพร้อมกัน
local uiVisible      = true

-- [STATE เพิ่มเติม] ระบบบันทึกตำแหน่งพิกัดกลับอัจฉริยะแบบแยกอิสระ
local savedPosition     = nil
local useSavePosEnabled = false 

-- [STATE เพิ่มใหม่] ระบบ Auto Equip
local autoEquipEnabled = false
local autoEquipThread  = nil
local selectedSlot     = 1 -- เริ่มต้นที่สล็อต 1 ตามค่าเริ่มต้นของ Dropdown

-- ========================
-- Maps & Configurations
-- ========================
local bossPaths = {
    ["Great Ape"]     = "GreatApe",
    ["Armored Titan"] = "ArmoredTitan",
    ["Crocodile"]     = "Crocodile",
}

local slotKeyCode = {
    [1] = Enum.KeyCode.One,
    [2] = Enum.KeyCode.Two,
    [3] = Enum.KeyCode.Three,
    [4] = Enum.KeyCode.Four,
    [5] = Enum.KeyCode.Five,
}

local hotbarSlotNames = { "Strength", "Sword", "Durability", "Chakra" }

-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true,  keyCode, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

-- ฟังก์ชันหาตำแหน่งบอสใน ClientEntities ตรงๆ ตามที่คุณระบุ
local function getBossPosition(bossName)
    local folderName = bossPaths[bossName]
    if not folderName then return nil end

    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if not clientEntities then return nil end

    local bossModel = clientEntities:FindFirstChild(folderName)
    if not bossModel then return nil end

    -- หาพิกัดจากชิ้นส่วนในตัวบอส
    local root = bossModel:FindFirstChild("HumanoidRootPart") 
        or bossModel:FindFirstChild("RootPart") 
        or bossModel.PrimaryPart

    if not root then
        for _, part in ipairs(bossModel:GetDescendants()) do
            if part:IsA("BasePart") then
                root = part
                break
            end
        end
    end

    return root and root.Position
end

-- เช็คว่า Slot มีของถืออยู่ไหม ดึงมาจากโค้ด Auto Equip ของคุณ 100%
local function isSlotEquipped()
    local success, result = pcall(function()
        local playerGui = LocalPlayer:WaitForChild("PlayerGui", 3)
        if not playerGui then return false end

        local main = playerGui:FindFirstChild("Main")
        if not main then return false end

        local hud = main:FindFirstChild("HUD")
        if not hud then return false end

        local hotbar = hud:FindFirstChild("Hotbar")
        if not hotbar then return false end

        for _, slotName in ipairs(hotbarSlotNames) do
            local slot = hotbar:FindFirstChild(slotName)
            if slot then
                local selectedFrame = slot:FindFirstChild("Selected")
                    or slot:FindFirstChild("Active")
                    or slot:FindFirstChild("Equipped")
                if selectedFrame and selectedFrame.Visible then
                    return true
                end
                if slot:IsA("GuiObject") then
                    local bg = slot.BackgroundTransparency
                    if bg ~= nil and bg < 0.9 then
                        return true
                    end
                end
            end
        end
        return false
    end)
    if success then
        return result
    end
    -- Fallback เช็ค Tool ใน Character
    local char = LocalPlayer.Character
    if char then
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Tool") then return true end
        end
    end
    return false
end

-- ========================
-- Auto Equip Logic (ปรับปรุงให้กดรอบเดียว และสแตนด์บายรอเกิดใหม่)
-- ========================
local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedSlot then return end
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        -- รันรอบแรกเพื่อตรวจสอบและกดใส่เพียงรอบเดียวเมื่อเลือกหรือเปิดใช้งาน
        if autoEquipEnabled and not isSlotEquipped() then
            local kc = slotKeyCode[selectedSlot]
            if kc then
                pressKey(kc)
                task.wait(0.5)
            end
        end
        
        -- เข้าสู่โหมดสแตนด์บายคอยตรวจจับสถานะ (ไม่กดซ้ำรัวๆ)
        while autoEquipEnabled do
            task.wait(0.5)
        end
    end)
end

-- ระบบตรวจจับเมื่อตัวละครตายแล้วเกิดใหม่ ให้ทำการรัน Auto Equip ใหม่อีกรอบทันที
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1.5) -- รอให้ตัวละครและ UI โหลดเสร็จหลังเกิดใหม่สักครู่
    if autoEquipEnabled then
        if not isSlotEquipped() then
            local kc = slotKeyCode[selectedSlot]
            if kc then
                pressKey(kc)
            end
        end
    end
end)

-- ========================
-- Farm Logic
-- ========================
local function stopFarm()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarm()
    stopFarm()
    
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local hasTarget = false
            
            -- ปรับปรุง: วนลูปสแกนบอสทุกตัวที่ถูกเลือกพร้อมกันในลิสต์
            for bossName, enabled in pairs(selectedBosses) do
                if not enabled then continue end
                
                local hrp = getHRP()
                local bossPos = getBossPosition(bossName)

                if hrp and bossPos then
                    -- วาร์ปไปพิกัดบอสโดยตรง
                    hrp.CFrame = CFrame.new(bossPos)
                    hasTarget = true
                    task.wait(0.2) -- ความเร็วในการตรวจสอบและวาร์ปซ้ำ
                end
            end
            
            -- เงื่อนไขระบบ Save Position: จะวาร์ปกลับจุดเซฟเมื่อเปิด Auto Boss อยู่และไม่เจอบอสตัวไหนเลย
            if not hasTarget then
                if useSavePosEnabled and savedPosition then
                    local hrp = getHRP()
                    if hrp then
                        hrp.CFrame = CFrame.new(savedPosition)
                    end
                end
                task.wait(0.3) -- รอตรวจสอบบอสในรอบถัดไป (ถ้าปิดฟาร์มอยู่ระบบจะไม่ทำงานตรงนี้ ทำให้เดินได้ปกติ)
            end
        end
    end)
end

