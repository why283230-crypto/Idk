-- ========================
-- Services
-- ========================
local Players             = game:GetService("Players")
local UserInputService    = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local HttpService         = game:GetService("HttpService")
local TeleportService     = game:GetService("TeleportService")
local LocalPlayer         = Players.LocalPlayer

-- ========================
-- State & Variables
-- ========================
local selectedMobs       = {}    -- เก็บรายชื่อมอนสเตอร์ที่เลือกไว้ (Multi-Select)
local availableMobs      = {}    -- เก็บรายชื่อมอนสเตอร์ทั้งหมดที่แสกนเจอ
local farmMobEnabled     = false -- สถานะการฟาร์ม
local farmMobThread      = nil   -- เธรดสคริปต์ฟาร์ม
local mobDropdown        = nil   -- ตัวแปรเก็บ Object ของ Dropdown เพื่อใช้อัปเดตข้อมูล

-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- ฟังก์ชันสแกนหาโมเดลมอนสเตอร์ใน workspace.ClientEntities
local function scanClientEntities()
    local mobsFound = {}
    local clientEntities = workspace:FindFirstChild("ClientEntities")
    
    if clientEntities then
        for _, child in ipairs(clientEntities:GetChildren()) do
            -- คัดเลือกเฉพาะ Object ที่เป็น Model และมีส่วนประกอบของร่างกาย หรือตามโครงสร้างของเกม
            if child:IsA("Model") and not table.find(mobsFound, child.Name) then
                table.insert(mobsFound, child.Name)
            end
        end
    end
    
    -- หากไม่เจออะไรเลย ให้มีค่า Default ป้องกัน UI เออเร่อ
    if #mobsFound == 0 then
        table.insert(mobsFound, "No Mobs Found")
    end
    
    table.sort(mobsFound)
    availableMobs = mobsFound
    return mobsFound
end

-- ฟังก์ชันหาตำแหน่งของมอนสเตอร์ตามชื่อที่ระบุ
local function getMobPosition(mobName)
    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if not clientEntities then return nil end
    
    for _, child in ipairs(clientEntities:GetChildren()) do
        if child.Name == mobName and child:IsA("Model") then
            local root = child:FindFirstChild("HumanoidRootPart") 
                or child:FindFirstChild("RootPart") 
                or child.PrimaryPart
                
            if not root then
                for _, part in ipairs(child:GetDescendants()) do
                    if part:IsA("BasePart") then root = part break end
                end
            end
            
            if root then
                return root.Position
            end
        end
    end
    return nil
end

-- ========================
-- Window Creation
-- ========================
local Window = WindUI:CreateWindow({
    Title       = "Test",
    Icon        = "swords",
    Author      = "Custom Developer",
    Folder      = "TestMobFarm",
    Size        = UDim2.fromOffset(450, 400),
    Theme       = "Dark",
