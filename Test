FloatBtn.Name             = "ToggleBtn"
FloatBtn.Parent           = FloatGui
FloatBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
FloatBtn.Position         = UDim2.new(0.05, 0, 0.3, 0)
FloatBtn.Size             = UDim2.fromOffset(52, 52)
FloatBtn.Text             = "T"
FloatBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
FloatBtn.Font             = Enum.Font.GothamBold
FloatBtn.TextSize         = 24
FloatBtn.Active           = true
FloatBtn.ZIndex           = 99999
FloatBtn.Visible          = false

FloatCorner.CornerRadius = UDim.new(0, 14)
FloatCorner.Parent       = FloatBtn

FloatStroke.Color     = Color3.fromRGB(0, 150, 255)
FloatStroke.Thickness = 2.5
FloatStroke.Parent    = FloatBtn

local dragging  = false
local dragInput = nil
local dragStart = nil
local startPos  = nil

FloatBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging  = true
        dragStart = input.Position
        startPos  = FloatBtn.Position
    end
end)

FloatBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

FloatBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and dragInput and input == dragInput then
        local delta = input.Position - dragStart
        FloatBtn.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

FloatBtn.MouseButton1Click:Connect(function()
    pcall(function()
        if Window.Toggle then Window:Toggle()
        elseif Window.Show then Window:Show() end
    end)
end)

task.spawn(function()
    while true do
        task.wait(0.5)
        pcall(function()
            local currentUiVisible = false
            for _, gui in ipairs(coreGui:GetChildren()) do
                if gui.Name == "WindUI" and gui:IsA("ScreenGui") then
                    currentUiVisible = gui.Enabled
                    break
                end
            end
            FloatBtn.Visible = not currentUiVisible
        end)
    end
end)

