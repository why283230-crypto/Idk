    Transparent = false,
})

task.wait(0.3)

-- เพิ่ม Category: Mob(for kills)
local MobTab = Window:Tab({ Title = "Mob(for kills)", Icon = "skull" })

MobTab:Section({ Title = "Monster Farming System" })

-- สแกนรายชื่อมอนสเตอร์ครั้งแรกก่อนสร้าง Dropdown
scanClientEntities()

-- เพิ่ม Dropdown สแกนหาโมเดล Mob (Multi-Select สามารถเลือกได้หลายตัว)
mobDropdown = MobTab:Dropdown({
    Title  = "Select Mobs to Farm", 
    Icon   = "ghost",
    Multi  = true, 
    Values = availableMobs,
    Callback = function(selectedList)
        selectedMobs = {}
        if type(selectedList) == "table" then
            for _, mobName in pairs(selectedList) do
                selectedMobs[mobName] = true
            end
        elseif type(selectedList) == "string" then
            selectedMobs[selectedList] = true
        end
    end,
})

-- ปุ่ม Refresh รายชื่อมอนสเตอร์ใน Dropdown
MobTab:Button({
    Title = "Refresh Mob List",
    Icon  = "refresh-cw",
    Callback = function()
        local newMobs = scanClientEntities()
        if mobDropdown and mobDropdown.Refresh then
            mobDropdown:Refresh(newMobs)
            WindUI:Notify({ Title = "Mob List Refreshed", Content = "Found " .. tostring(#newMobs) .. " types of mobs.", Duration = 3, Icon = "check-circle" })
        else
            WindUI:Notify({ Title = "Error", Content = "Cannot refresh dropdown", Duration = 3, Icon = "alert-circle" })
        end
    end,
})

MobTab:Divider()

-- ฟังก์ชันลูปวาร์ปไปหามอนสเตอร์ที่เลือก
local function updateMobFarmState()
    if not farmMobEnabled then
        if farmMobThread then task.cancel(farmMobThread) farmMobThread = nil end
        return
    end
    
    farmMobThread = task.spawn(function()
        while farmMobEnabled do
            local teleportsDone = false
            
            for mobName, isSelected in pairs(selectedMobs) do
                if not farmMobEnabled then break end
                if isSelected and mobName ~= "No Mobs Found" then
                    local pos = getMobPosition(mobName)
                    local hrp = getHRP()
                    
                    if hrp and pos then
                        -- วาร์ปไปหาพิกัดของมอนสเตอร์ตัวนั้นๆ โดยบวกความสูงแกน Y เพิ่มไป 5 หน่วย เพื่อให้อยู่บนหัว
                        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
                        teleportsDone = true
                        task.wait(0.5) -- หน่วงเวลาในการวาร์ป 0.5 วินาทีตามที่ต้องการ
                    end
                end
            end
            
            if not teleportsDone then
                task.wait(0.5) -- หากไม่เจอมอนสเตอร์ที่เลือก ให้รอซักครู่แล้วตรวจสอบใหม่
            else
                task.wait(0.1)
            end
        end
    end)
end

-- ปุ่มเปิด/ปิด เริ่มต้นการฟาร์ม (Start Farm Mob)
MobTab:Toggle({
    Title = "Start Farm Mob", 
    Icon = "play",
    Value = false,
    Callback = function(state)
        farmMobEnabled = state
        if state then
            -- ตรวจสอบว่าได้เลือกมอนสเตอร์ไว้หรือยัง
            local hasSelection = false
            for _, v in pairs(selectedMobs) do if v then hasSelection = true break end end
            
            if not hasSelection then
                WindUI:Notify({ Title = "Warning", Content = "Please select at least one mob from dropdown!", Duration = 4, Icon = "alert-triangle" })
            else
                WindUI:Notify({ Title = "Mob Farming Started ✅", Content = "Teleporting to selected targets...", Duration = 3, Icon = "check" })
            end
            updateMobFarmState()
        else
            farmMobEnabled = false
            updateMobFarmState()
            WindUI:Notify({ Title = "Mob Farming Stopped ❌", Content = "Stopped teleportation", Duration = 3, Icon = "x" })
        end
    end,
})

