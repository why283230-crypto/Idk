-- ดักจับการสลับหน้าต่างผ่าน Background Loop ที่แม่นยำและไม่หน่วงเครื่อง
task.spawn(function()
    task.wait(1)
    while true do
        task.wait(0.3)
        pcall(function()
            if Window and Window.Main then
                -- เช็คโดยตรงจาก Property .Visible ของเฟรมหลักใน WindUI
                local actualVisible = Window.Main.Visible
                if actualVisible ~= menuOpenState then
                    menuOpenState = actualVisible
                    FloatBtn.Visible = not actualVisible
                end
            end
        end)
    end
end)

