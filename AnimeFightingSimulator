    while true do
        task.wait(0.4)
        pcall(function()
            if windMainContainer then
                local isCurrentlyVisible = windMainContainer.Visible
                if isCurrentlyVisible ~= uiVisible then
                    uiVisible = isCurrentlyVisible
                    FloatBtn.Visible = not isCurrentlyVisible
                end
            else
                -- ค้นหาสำรองเผื่อ UI โดนรีเซ็ตเมื่อตัวละครตาย
