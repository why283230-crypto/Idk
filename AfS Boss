-- MonHub | Farm Boss
-- Wind UI Latest Version

local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/source.lua"))()

-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local LocalPlayer = Players.LocalPlayer

-- State Variables
local savedPosition = nil
local farmingEnabled = false
local farmThread = nil
local autoEquipEnabled = false
local autoEquipThread = nil
local selectedEquipSlot = nil
local selectedBosses = {}
local spacebarLoopEnabled = false
local spacebarThread = nil

-- Helper: Get Character Parts
local function getHRP()
    local char = LocalPlayer.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
end

-- Helper: Teleport
local function teleportTo(pos)
    local hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(pos)
    end
end

-- Helper: Find Boss Center Position
local function findBoss(bossKey)
    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if not clientEntities then return nil end

    local bossModel = clientEntities:FindFirstChild(bossKey)
    if not bossModel then return nil end

    local root = bossModel:FindFirstChild("HumanoidRootPart")
        or bossModel:FindFirstChild("RootPart")
        or bossModel:FindFirstChildWhichIsA("BasePart")

    if root then
        return root.Position
    end

    return nil
end

-- Boss Config
local bossKeys = {
    ["Crocodile"] = "Crocodile",
    ["Armored Titan"] = "ArmoredTitan",
    ["Great Ape"] = "GreatApe",
}

-- Helper: Press Key (VirtualInputManager)
local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

-- Helper: Is Holding Tool
local function isHoldingTool()
    local char = LocalPlayer.Character
    if char then
        return char:FindFirstChildOfClass("Tool") ~= nil
    end
    return false
end

-- Slot Key Map
local slotKeys = {
    [1] = Enum.KeyCode.One,
    [2] = Enum.KeyCode.Two,
    [3] = Enum.KeyCode.Three,
    [4] = Enum.KeyCode.Four,
    [5] = Enum.KeyCode.Five,
}

-- ========================
-- Start/Stop Functions
-- ========================

local function stopFarming()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarming()
    stopFarming()
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local bossFound = false

            for bossName, key in pairs(selectedBosses) do
                if not key then continue end
                local bossKeyStr = bossKeys[bossName]
                if not bossKeyStr then continue end

                local pos = findBoss(bossKeyStr)
                if pos then
                    teleportTo(pos)
                    bossFound = true
                    task.wait(0.3)
                end
            end

            if not bossFound then
                -- No boss found → teleport to saved position
                if savedPosition then
                    teleportTo(savedPosition)
                end
            end

            task.wait(0.5)
        end
    end)
end

local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedEquipSlot then return end
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            if not isHoldingTool() then
                local keyCode = slotKeys[selectedEquipSlot]
                if keyCode then
                    pressKey(keyCode)
                end
            end
            task.wait(0.3)
        end
    end)
end

