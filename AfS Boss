-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(pos)
    local hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(pos)
    end
end

-- [BUG FIX 3 - เสมือนกดคีย์บอร์ดจริง]
local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.02) -- หน่วงเวลาเสมือนนิ้วกดลงไปจริงๆ
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

-- [BUG FIX 1 - ค้นหาบอสตรงพิกัดและแม่นยำขึ้น]
local function findBossPosition(bossName)
    local key = bossModelKey[bossName]
    if not key then return nil end

    -- ตรวจสอบทั้งใน Workspace หลักและ ClientEntities
    local targets = {workspace, workspace:FindFirstChild("ClientEntities")}
    local model = nil

    for _, parent in ipairs(targets) do
        if parent then
            model = parent:FindFirstChild(key)
            if model then break end
        end
    end

    if not model then return nil end

    local root = model:FindFirstChild("HumanoidRootPart") 
        or model:FindFirstChild("RootPart") 
        or model:PrimaryPart

    if not root then
        for _, part in ipairs(model:GetDescendants()) do
            if part:IsA("BasePart") then
                root = part
                break
            end
        end
    end

    if root then
        return root.Position
    end

    return nil
end

-- [BUG FIX 2 - ตรวจจับจากภาพหน้าจอ Hotbar และเช็ค UIStroke/ความโปร่งใสเพื่อหยุดกดซ้ำ]
local function isSlotEquipped()
    local equipped = false
    pcall(function()
        local playerGui = LocalPlayer:WaitForChild("PlayerGui", 3)
        if not playerGui then return end

        -- สแกนหา Hotbar UI ในลักษณะ Dynamic ป้องกันชื่อ Path เปลี่ยน
        local hotbar = playerGui:FindFirstChild("Hotbar", true) 
            or playerGui:FindFirstChild("Main", true) and playerGui.Main:FindFirstChild("HUD", true) and playerGui.Main.HUD:FindFirstChild("Hotbar")

        if hotbar then
            -- ค้นหาช่องตามตัวเลข Slot ที่เลือก (เช็คจากเลข 1, 2, 3 บนภาพ)
            local targetSlotStr = tostring(selectedSlot)
            for _, child in ipairs(hotbar:GetDescendants()) do
                if child:IsA("TextLabel") and child.Text == targetSlotStr then
                    -- เมื่อเจอตัวเลขสล็อต ให้เช็ค Frame หลักของมันว่าเลือกอยู่ไหม
                    local slotFrame = child.Parent
                    if slotFrame then
                        -- 1. เช็ค UIStroke (จากภาพที่ 1) ถ้าขอบสว่างหรือหนาขึ้นแสดงว่าเลือกอยู่
                        local stroke = slotFrame:FindFirstChildOfClass("UIStroke")
                        if stroke and stroke.Enabled and stroke.Thickness > 0 then
                            equipped = true
                            return
                        end
                        -- 2. เช็ค Background หรือ Frame ไฮไลท์ซ้อนข้างใน
                        local activeIndicator = slotFrame:FindFirstChild("Selected") or slotFrame:FindFirstChild("Active")
                        if activeIndicator and activeIndicator.Visible then
                            equipped = true
                            return
                        end
                        -- 3. เช็คความทึบแสง (ถ้าถูกเลือกมักจะทึบขึ้น)
                        if slotFrame:IsA("GuiObject") and slotFrame.BackgroundTransparency < 0.3 then
                            equipped = true
                            return
                        end
                    end
                end
            end
        end
    end)

    -- Fallback: ตรวจสอบ Tool ในตัวละครจริง
    if not equipped then
        local char = LocalPlayer.Character
        if char then
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Tool") then
                    equipped = true
                    break
                end
            end
        end
    end

    return equipped
end

-- ========================
-- Farm Logic
-- ========================
local function stopFarm()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarm()
    stopFarm()
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local found = false

            for bossName, enabled in pairs(selectedBosses) do
                if not enabled then continue end

                local pos = findBossPosition(bossName)
                if pos then
                    teleportTo(pos)
                    found = true
                    task.wait(0.2)
                else
                    task.wait(0.1)
                end
            end

            if not found and savedPosition then
                teleportTo(savedPosition)
            end

            task.wait(0.3)
        end
    end)
end

-- ========================
-- Auto Equip Logic
-- ========================
local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedSlot then return end
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            if not isSlotEquipped() then
                local kc = slotKeyCode[selectedSlot]
                if kc then
                    pressKey(kc)
                    task.wait(0.3) -- รอระบบเซิร์ฟเวอร์ตอบสนองการถือของ
                end
            else
                task.wait(0.5) -- ถืออยู่แล้ว ให้รอวนตรวจเช็คอย่างเดียว ไม่กดซ้ำรัวๆ
            end
        end
    end)
end

-- ========================
-- Auto Skill Logic
-- ========================
local function stopAutoSkill()
    autoSkillEnabled = false
    if autoSkillThread then
        task.cancel(autoSkillThread)
        autoSkillThread = nil
    end
end

local function startAutoSkill()
    stopAutoSkill()
    autoSkillEnabled = true
    autoSkillThread = task.spawn(function()
        while autoSkillEnabled do
            local hasKey = false
            for letter, active in pairs(selectedSkillKeys) do
                if not active then continue end
                local kc = letterKeyCode[letter]
                if kc then
                    pressKey(kc) -- ใช้ฟังก์ชันกดเสมือนคีย์บอร์ดจริง
                    hasKey = true
                    task.wait(0.1) -- เว้นช่วงระหว่างการกดแต่ละสกิล
                end
            end
            if not hasKey then
                task.wait(0.2)
            end
        end
    end)
end

