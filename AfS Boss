                Content = "กำลัง Farm บอสที่เลือกไว้",
                Duration = 3,
                Icon = "play",
            })
        else
            stopFarming()
            WindUI:Notify({
                Title = "⏹ Auto Farm ปิดแล้ว",
                Content = "หยุด Farm บอส",
                Duration = 2,
                Icon = "square",
            })
        end
    end,
})

-- ========================
-- Auto Equip Tab
-- ========================

EquipTab:Dropdown({
    Title = "เลือก Slot (1-5)",
    Description = "เลือก Slot ที่ต้องการ Auto Equip (เลือกได้แค่อันเดียว)",
    Values = {"Slot 1", "Slot 2", "Slot 3", "Slot 4", "Slot 5"},
    Multi = false,
    Default = "Slot 1",
    Callback = function(selected)
        local num = tonumber(string.match(selected, "%d"))
        selectedEquipSlot = num
        -- Restart if already running
        if autoEquipEnabled then
            startAutoEquip()
        end
    end,
})

EquipTab:Separator()

EquipTab:Toggle({
    Title = "🎒 Auto Equip",
    Description = "กดปุ่ม Slot ที่เลือกวนซ้ำ หากตรวจพบว่าถือของอยู่แล้วจะข้ามไป",
    Default = false,
    Callback = function(state)
        if state then
            startAutoEquip()
            WindUI:Notify({
                Title = "✅ Auto Equip เปิดแล้ว",
                Content = "Slot: " .. tostring(selectedEquipSlot),
                Duration = 3,
                Icon = "check-circle",
            })
        else
            stopAutoEquip()
            WindUI:Notify({
                Title = "⏹ Auto Equip ปิดแล้ว",
                Duration = 2,
                Icon = "x-circle",
            })
        end
    end,
})

