-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(pos)
    local hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(pos)
    end
end

-- [BUG FIX 1] Auto Farm: วาปตรงๆ ไปที่ path ที่กำหนด
local function findBossPosition(bossName)
    local key = bossModelKey[bossName]
    if not key then return nil end

    -- วาปตรงไปที่ workspace.ClientEntities.<BossName>
    local ok, model = pcall(function()
        return workspace.ClientEntities[key]
    end)
    if not ok or not model then return nil end

    -- หา HumanoidRootPart หรือ Part แรกที่เจอ
    local root = model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("RootPart")
    if not root then
        for _, v in ipairs(model:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide then
                root = v
                break
            end
        end
        -- ถ้ายังไม่เจอ ลอง BasePart ใดก็ได้
        if not root then
            for _, v in ipairs(model:GetDescendants()) do
                if v:IsA("BasePart") then
                    root = v
                    break
                end
            end
        end
    end

    return root and root.Position or nil
end

-- [BUG FIX 2] Auto Skill: ใช้ keypress แบบ keyboard จริงๆ
-- ใช้ InputObject simulate แทน SendKeyEvent เพื่อให้ game รับได้
local function pressKeyOnce(keyCode)
    -- ลองทั้ง 2 วิธี ให้ได้ผลแน่นอน
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    end)
    task.wait(0.06)
    pcall(function()
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

local function pressKey(keyCode)
    pressKeyOnce(keyCode)
end

-- [BUG FIX 3] Auto Equip: ตรวจจับจากสีพื้นหลัง Slot ใน Hotbar
-- จากรูป: Slot ที่ equipped = พื้นหลังขาว/สว่าง (BackgroundColor3 ใกล้ขาว หรือ ImageTransparency ต่ำ)
local hotbarSlotNames = {"Strength", "Sword", "Durability", "Chakra"}

local function getHotbarSlot(slotIndex)
    -- ลอง path ที่เป็นไปได้
    local ok, hotbar = pcall(function()
        return LocalPlayer.PlayerGui.Main.HUD.Hotbar
    end)
    if not ok or not hotbar then return nil end

    -- ลองหาด้วยชื่อ slot โดยตรง
    local slotName = hotbarSlotNames[slotIndex]
    if slotName then
        local slot = hotbar:FindFirstChild(slotName)
        if slot then return slot end
    end

    -- fallback: หาจาก index (children ตาม order)
    local children = hotbar:GetChildren()
    -- กรองเฉพาะ GuiObject
    local guiSlots = {}
    for _, c in ipairs(children) do
        if c:IsA("GuiObject") then
            table.insert(guiSlots, c)
        end
    end
    if guiSlots[slotIndex] then
        return guiSlots[slotIndex]
    end

    return nil
end

local function isSlotEquipped()
    local ok, result = pcall(function()
        local slot = getHotbarSlot(selectedSlot or 1)
        if not slot then return false end

        -- [FIX] จากรูป: Slot ที่ equipped มีพื้นหลังสีขาว
        -- เช็ค BackgroundColor3 ว่าสว่างไหม (R+G+B > 2.5 ≈ ขาว)
        local bg = slot.BackgroundColor3
        local brightness = bg.R + bg.G + bg.B
        if brightness > 2.5 then
            return true
        end

        -- เช็ค BackgroundTransparency: equipped = ไม่โปร่งใส (< 0.5)
        if slot.BackgroundTransparency < 0.5 then
            return true
        end

        -- เช็ค child ชื่อ "Equipped", "Selected", "Active", "Highlight"
        for _, child in ipairs(slot:GetChildren()) do
            local name = child.Name:lower()
            if (name == "equipped" or name == "selected"
                or name == "active" or name == "highlight"
                or name == "outline") then
                if child:IsA("GuiObject") and child.Visible then
                    -- เช็คสีของ child ด้วยว่าขาวไหม
                    if child:IsA("Frame") or child:IsA("ImageLabel") then
                        local c = child.BackgroundColor3
                        if (c.R + c.G + c.B) > 2.5 then
                            return true
                        end
                        -- หรือแค่ Visible ก็พอ
                        return true
                    end
                    return true
                end
            end
        end

        return false
    end)

    if ok then return result end

    -- fallback: เช็ค Tool ใน Character
    local char = LocalPlayer.Character
    if char then
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Tool") then return true end
        end
    end
    return false
end

-- ========================
-- Farm Logic [BUG FIX 1]
-- ========================
local function stopFarm()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarm()
    stopFarm()
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local found = false

            for bossName, enabled in pairs(selectedBosses) do
                if not enabled then continue end

                local pos = findBossPosition(bossName)
                if pos then
                    teleportTo(pos)
                    found = true
                    task.wait(0.3)
                else
                    task.wait(0.1)
                end
            end

            if not found then
                if savedPosition then
                    teleportTo(savedPosition)
                end
            end

            task.wait(0.5)
        end
    end)
end

-- ========================
-- Auto Equip Logic [BUG FIX 3]
-- ========================
local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedSlot then return end
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            if not isSlotEquipped() then
                local kc = slotKeyCode[selectedSlot]
                if kc then
                    pressKey(kc)
                    task.wait(0.5)
                end
            else
                task.wait(0.5)
            end
        end
    end)
end

-- ========================
-- Auto Skill Logic [BUG FIX 2]
-- ========================
local function stopAutoSkill()
    autoSkillEnabled = false
    if autoSkillThread then
        task.cancel(autoSkillThread)
        autoSkillThread = nil
    end
end

local function startAutoSkill()
    stopAutoSkill()
    autoSkillEnabled = true
    autoSkillThread = task.spawn(function()
        while autoSkillEnabled do
            local hasKey = false
            for letter, active in pairs(selectedSkillKeys) do
                if not active then continue end
                local kc = letterKeyCode[letter]
                if kc then
                    -- [FIX] กดแบบ keyboard จริงๆ Down แล้ว Up
                    pcall(function()
                        VirtualInputManager:SendKeyEvent(true, kc, false, game)
                    end)
                    task.wait(0.06)
                    pcall(function()
                        VirtualInputManager:SendKeyEvent(false, kc, false, game)
                    end)
                    task.wait(0.06)
                    hasKey = true
                end
            end
            if not hasKey then
                task.wait(0.1)
            end
        end
    end)
end

