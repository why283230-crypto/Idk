-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(pos)
    local hrp = getHRP()
    if hrp then
        -- ออฟเซ็ตขึ้นเล็กน้อยเพื่อไม่ให้ติดพื้น
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
    end
end

-- [BUG FIX] ปรับวิธีหา Boss ให้แม่นยำขึ้น
local function findBossPosition(bossName)
    local key = bossModelKey[bossName]
    if not key then return nil end

    local ce = workspace:FindFirstChild("ClientEntities")
    if not ce then return nil end

    local model = ce:FindFirstChild(key)
    if not model then return nil end

    -- ตรวจสอบว่า Model ยังมีชีวิต (มี Humanoid และ Health > 0)
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health <= 0 then
        return nil
    end

    local root = model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("RootPart")
        or model:FindFirstChildWhichIsA("BasePart")

    if root then
        return root.Position
    end

    return nil
end

local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true,  keyCode, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

-- [BUG FIX] ตรวจจับ Tool ที่ถืออยู่ให้แม่นขึ้น
local function isHoldingTool()
    local char = LocalPlayer.Character
    if not char then return false end
    -- เช็คทั้งใน Character และใน Backpack ที่ Equipped
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then
            return true
        end
    end
    return false
end

-- ========================
-- Farm Logic [BUG FIX]
-- ========================
local function stopFarm()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarm()
    stopFarm()
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local found = false

            -- วนหาบอสทุกตัวที่เลือก
            for bossName, enabled in pairs(selectedBosses) do
                if not enabled then continue end

                local pos = findBossPosition(bossName)
                if pos then
                    teleportTo(pos)
                    found = true
                    -- [FIX] รอให้ Teleport เสร็จก่อนค่อยวนต่อ
                    task.wait(0.3)
                else
                    -- บอสนี้หาไม่เจอ ลองบอสถัดไป
                    task.wait(0.1)
                end
            end

            -- หาไม่เจอสักตัว → วาปกลับ
            if not found then
                if savedPosition then
                    teleportTo(savedPosition)
                end
            end

            task.wait(0.5)
        end
    end)
end

-- ========================
-- Auto Equip Logic [BUG FIX]
-- ========================
local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedSlot then return end
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            -- [FIX] เช็คก่อนกด
            if not isHoldingTool() then
                local kc = slotKeyCode[selectedSlot]
                if kc then
                    pressKey(kc)
                    -- [FIX] รอให้ Tool Equip ก่อนเช็คซ้ำ
                    task.wait(0.5)
                end
            else
                -- ถือของอยู่แล้ว รอนานขึ้นก่อนเช็คใหม่
                task.wait(0.5)
            end
        end
    end)
end

-- ========================
-- Auto Skill Logic (NEW)
-- ========================
local function stopAutoSkill()
    autoSkillEnabled = false
    if autoSkillThread then
        task.cancel(autoSkillThread)
        autoSkillThread = nil
    end
end

local function startAutoSkill()
    stopAutoSkill()
    autoSkillEnabled = true
    autoSkillThread = task.spawn(function()
        while autoSkillEnabled do
            local hasKey = false
            for letter, active in pairs(selectedSkillKeys) do
                if not active then continue end
                local kc = letterKeyCode[letter]
                if kc then
                    pressKey(kc)
                    hasKey = true
                    task.wait(0.05)
                end
            end
            -- ถ้าไม่มี key เลยให้รอก่อนไม่ให้ loop ร้อน
            if not hasKey then
                task.wait(0.1)
            end
        end
    end)
end

