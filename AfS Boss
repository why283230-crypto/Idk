-- MonHub | Farm Boss
-- Wind UI v1.6.64-fix (Selected Version - Recommended)
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- ========================
-- Services
-- ========================
local Players        = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")

local LocalPlayer = Players.LocalPlayer

-- ========================
-- State
-- ========================
local savedPosition   = nil
local farmingEnabled  = false
local farmThread      = nil

local autoEquipEnabled = false
local autoEquipThread  = nil
local selectedSlot     = nil  -- number 1-5

local spaceLoopEnabled = false
local spaceThread      = nil

local selectedBosses = {}
-- selectedBosses["Crocodile"] = true/nil  (multi dropdown returns table of name=bool)

-- ========================
-- Boss Key Map
-- ========================
local bossModelKey = {
    ["Crocodile"]    = "Crocodile",
    ["Armored Titan"] = "ArmoredTitan",
    ["Great Ape"]    = "GreatApe",
}

-- ========================
-- Slot KeyCode Map
-- ========================
local slotKeyCode = {
    [1] = Enum.KeyCode.One,
    [2] = Enum.KeyCode.Two,
    [3] = Enum.KeyCode.Three,
    [4] = Enum.KeyCode.Four,
    [5] = Enum.KeyCode.Five,
}

-- ========================
-- Helpers
-- ========================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(pos)
    local hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(pos)
    end
end

local function findBossPosition(bossName)
    local key = bossModelKey[bossName]
    if not key then return nil end

    local ce = workspace:FindFirstChild("ClientEntities")
    if not ce then return nil end

    local model = ce:FindFirstChild(key)
    if not model then return nil end

    local root = model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("RootPart")
        or model:FindFirstChildWhichIsA("BasePart")

    return root and root.Position or nil
end

local function pressKey(keyCode)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true,  keyCode, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

local function isHoldingTool()
    local char = LocalPlayer.Character
    return char and char:FindFirstChildOfClass("Tool") ~= nil
end

-- ========================
-- Farm Logic
-- ========================
local function stopFarm()
    farmingEnabled = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
end

local function startFarm()
    stopFarm()
    farmingEnabled = true
    farmThread = task.spawn(function()
        while farmingEnabled do
            local found = false

            for bossName, enabled in pairs(selectedBosses) do
                if not enabled then continue end
                local pos = findBossPosition(bossName)
                if pos then
                    teleportTo(pos)
                    found = true
                end
                task.wait(0.2)
            end

            if not found then
                if savedPosition then
                    teleportTo(savedPosition)
                end
            end

            task.wait(0.5)
        end
    end)
end

-- ========================
-- Auto Equip Logic
-- ========================
local function stopAutoEquip()
    autoEquipEnabled = false
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedSlot then return end
    autoEquipEnabled = true
    autoEquipThread = task.spawn(function()
        while autoEquipEnabled do
            if not isHoldingTool() then
                local kc = slotKeyCode[selectedSlot]
                if kc then
                    pressKey(kc)
                end
            end
            task.wait(0.3)
        end
    end)
end

-- ========================
-- Window
-- ========================
local Window = WindUI:CreateWindow({
    Title  = "MonHub | Farm Boss",
    Icon   = "swords",
    Author = "MonHub",
    Folder = "MonHub",
    Size   = UDim2.fromOffset(580, 460),
    Theme  = "Dark",
    Acrylic = true,
    Transparent = true,
})

-- ========================
-- Tab: Farm Boss
-- ========================
local FarmTab = Window:Tab({
    Title = "Farm Boss",
    Icon  = "crosshair",
})

-- Save Position Button
FarmTab:Button({
    Title = "Save Position",
    Desc  = "บันทึกตำแหน่งปัจจุบัน หากหาบอสไม่เจอจะวาปกลับที่นี่",
    Icon  = "map-pin",
    Callback = function()
        local hrp = getHRP()
        if hrp then
            savedPosition = hrp.Position
            WindUI:Notify({
                Title   = "Position Saved",
                Content = ("X:%.1f  Y:%.1f  Z:%.1f"):format(
                    savedPosition.X, savedPosition.Y, savedPosition.Z),
                Duration = 4,
                Icon     = "map-pin",
            })
        else
            WindUI:Notify({
                Title    = "Error",
                Content  = "ไม่พบตัวละคร กรุณา Spawn ก่อน",
                Duration = 3,
                Icon     = "alert-circle",
            })
        end
    end,
})

FarmTab:Divider()

-- Boss Multi-Select Dropdown
FarmTab:Dropdown({
    Title  = "เลือก Boss",
    Desc   = "เลือกได้หลายบอสพร้อมกัน",
    Icon   = "list",
    Values = { "Crocodile", "Armored Titan", "Great Ape" },
    Multi  = true,
    AllowNone = true,
    Callback = function(selected)
        -- selected = { ["Crocodile"] = true, ... }
        selectedBosses = selected
    end,
})

FarmTab:Divider()

-- Auto Farm Toggle
FarmTab:Toggle({
    Title = "Auto Farm Boss",
    Desc  = "วน Teleport ไปตรงกลางบอสที่เลือก / วาปกลับหากหาไม่เจอ",
    Icon  = "zap",
    Value = false,
    Callback = function(state)
        if state then
            startFarm()
            WindUI:Notify({
                Title    = "Auto Farm เปิดแล้ว",
                Content  = "กำลัง Farm บอสที่เลือกไว้",
                Duration = 3,
                Icon     = "play",
            })
        else
            stopFarm()
            WindUI:Notify({
                Title    = "Auto Farm ปิดแล้ว",
                Duration = 2,
                Icon     = "square",
            })
        end
    end,
})

-- ========================
-- Tab: Auto Equip
-- ========================
local EquipTab = Window:Tab({
    Title = "Auto Equip",
    Icon  = "backpack",
})

-- Slot Dropdown (Single)
EquipTab:Dropdown({
    Title  = "เลือก Slot ที่จะ Equip",
    Desc   = "กดปุ่มตัวเลขนั้นซ้ำๆ หากถือของอยู่แล้วจะข้ามไป",
    Icon   = "hash",
    Values = { "Slot 1", "Slot 2", "Slot 3", "Slot 4", "Slot 5" },
    Value  = "Slot 1",
    Callback = function(selected)
        local num = tonumber(selected:match("%d"))
        selectedSlot = num
        if autoEquipEnabled then
            startAutoEquip()
        end
    end,
})

EquipTab:Divider()

-- Auto Equip Toggle
EquipTab:Toggle({
    Title = "Auto Equip",
    Desc  = "เปิด/ปิด การกดปุ่ม Slot อัตโนมัติ",
    Icon  = "shield",
    Value = false,
    Callback = function(state)
        if state then
            startAutoEquip()
            WindUI:Notify({
                Title    = "Auto Equip เปิดแล้ว",
                Content  = "Slot: " .. tostring(selectedSlot or "?"),
                Duration = 3,
                Icon     = "check-circle",
            })
        else
            stopAutoEquip()
            WindUI:Notify({
                Title    = "Auto Equip ปิดแล้ว",
                Duration = 2,
                Icon     = "x-circle",
            })
        end
    end,
})

-- ========================
-- Tab: Utilities
-- ========================
local UtilTab = Window:Tab({
    Title = "Utilities",
    Icon  = "settings",
})

-- Spacebar single press
UtilTab:Button({
    Title = "กด Spacebar (ครั้งเดียว)",
    Desc  = "ทดสอบกด Space 1 ครั้ง",
    Icon  = "arrow-up",
    Callback = function()
        pressKey(Enum.KeyCode.Space)
        WindUI:Notify({
            Title    = "Spacebar Pressed",
            Content  = "กด Space แล้ว 1 ครั้ง",
            Duration = 2,
            Icon     = "zap",
        })
    end,
})

UtilTab:Divider()

-- Spacebar Loop Toggle
UtilTab:Toggle({
    Title = "Spacebar Loop",
    Desc  = "กด Spacebar วนซ้ำอัตโนมัติทุก 0.5 วิ เพื่อทดสอบ",
    Icon  = "repeat",
    Value = false,
    Callback = function(state)
        spaceLoopEnabled = state
        if state then
            spaceThread = task.spawn(function()
                while spaceLoopEnabled do
                    pressKey(Enum.KeyCode.Space)
                    task.wait(0.5)
                end
            end)
            WindUI:Notify({
                Title    = "Spacebar Loop เปิดแล้ว",
                Duration = 2,
                Icon     = "repeat",
            })
        else
            if spaceThread then
                task.cancel(spaceThread)
                spaceThread = nil
            end
            WindUI:Notify({
                Title    = "Spacebar Loop ปิดแล้ว",
                Duration = 2,
                Icon     = "square",
            })
        end
    end,
})

