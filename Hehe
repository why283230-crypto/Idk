local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Auto Farm Boss Hub",
   LoadingTitle = "Loading Script...",
   LoadingSubtitle = "by Gemini AI",
   ConfigurationSaving = {
      Enabled = false
   },
   KeySystem = false
})

-- // Variables (ตัวแปรควบคุมระบบ) //
local LocalPlayer = game.Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local VirtualInputManager = game:GetService("VirtualInputManager")
local TweenService = game:GetService("TweenService")

-- โครงสร้างข้อมูลบอส
local BossConfig = {
    ["Crocodile"] = workspace.ClientEntities:FindFirstChild("Crocodile"),
    ["Armored Titan"] = workspace.ClientEntities:FindFirstChild("ArmoredTitan"),
    ["Great Ape"] = workspace.ClientEntities:FindFirstChild("GreatApe")
}

-- สถานะการทำงานต่างๆ
local SelectedBosses = {}
local AutoFarmEnabled = false
local SavedPosition = nil

local SelectedSlot = "1"
local AutoEquipEnabled = false

local SelectedSkills = {}
local AutoSkillEnabled = false

-- // รีเฟรช Character เมื่อตาย/เกิดใหม่ //
LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char
end)

-- // ฟังก์ชันช่วย (Utility Functions) //
local function Teleport(cframe)
    if Character and Character:FindFirstChild("HumanoidRootPart") then
        Character.HumanoidRootPart.CFrame = cframe
    end
end

-- ฟังก์ชันกดปุ่มคีย์บอร์ดจำลอง
local function PressKey(key)
    VirtualInputManager:SendKeyEvent(true, key, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, key, false, game)
end

-- // --- TABS --- //
local MainTab = Window:CreateTab("Main Farm", 4483362458)
local CombatTab = Window:CreateTab("Combat & Skills", 4483362458)

-- // ================= MAIN FARM TAB ================= //

MainTab:CreateSection("Saved Position")

MainTab:CreateButton({
   Name = "Save Current Position (เซฟพิกัด)",
   Callback = function()
       if Character and Character:FindFirstChild("HumanoidRootPart") then
           SavedPosition = Character.HumanoidRootPart.CFrame
           Rayfield:Notify({
              Title = "Position Saved!",
              Content = "บันทึกตำแหน่งปัจจุบันของคุณเรียบร้อยแล้ว",
              Duration = 3,
              Image = 4483362458,
           })
       end
   end,
})

MainTab:CreateSection("Boss Farming")

MainTab:CreateDropdown({
   Name = "Select Bosses (เลือกบอส - เลือกได้หลายตัว)",
   Options = {"Crocodile", "Armored Titan", "Great Ape"},
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options)
       SelectedBosses = Options
   end,
})

MainTab:CreateToggle({
   Name = "Auto Farm Boss",
   CurrentValue = false,
   Flag = "AutoFarmFlag",
   Callback = function(Value)
       AutoFarmEnabled = Value
       
       if AutoFarmEnabled then
           task.spawn(function()
               while AutoFarmEnabled do
                   local bossFound = false
                   
                   -- วนลูปหาบอสตามที่เลือกไว้ใน Dropdown
                   for bossName, isSelected in pairs(SelectedBosses) do
                       if isSelected then
                           -- อัปเดต Reference เผื่อบอสเกิดใหม่
                           local bossModelName = bossName == "Armored Titan" and "ArmoredTitan" or (bossName == "Great Ape" and "GreatApe" or "Crocodile")
                           local bossModel = workspace.ClientEntities:FindFirstChild(bossModelName)
                           
                           if bossModel and bossModel:FindFirstChild("HumanoidRootPart") then
                               bossFound = true
                               -- วาร์ปไปตรงกลางตัวบอส
                               Teleport(bossModel.HumanoidRootPart.CFrame)
                               break -- เจอบอสตัวนึงแล้ว ให้ทำตัวนี้ก่อนในลูปนี้
                           end
                       end
                   end
                   
                   -- ถ้าไม่เจอบอสตัวไหนเลยที่เลือกไว้ ให้วาร์ปกลับจุดเซฟ
                   if not bossFound and SavedPosition then
                       Teleport(SavedPosition)
                   end
                   
                   task.wait(0.5) -- หน่วงเวลาเช็คบอสทุกๆ 0.5 วินาที
               end
           end)
       end
   end,
})

-- // ================= COMBAT & SKILLS TAB ================= //

CombatTab:CreateSection("Auto Equip")

CombatTab:CreateDropdown({
   Name = "Select Slot (เลือกเลขปุ่มถือของ)",
   Options = {"1", "2", "3", "4", "5"},
   CurrentOption = {"1"},
   MultipleOptions = false,
   Callback = function(Option)
       SelectedSlot = Option[1]
   end,
})

CombatTab:CreateToggle({
   Name = "Auto Equip Item",
   CurrentValue = false,
   Callback = function(Value)
       AutoEquipEnabled = Value
       
       if AutoEquipEnabled then
           task.spawn(function()
               while AutoEquipEnabled do
                   if Character then
                       -- ตรวจสอบว่าในตัวมีการถือ Tool (ของ) อยู่หรือไม่
                       local holdingItem = Character:FindFirstChildOfClass("Tool")
                       
                       if not holdingItem then
                           -- ถ้ายังไม่ได้ถือของ ให้กดเลข slot นั้นๆ
                           local keyEnum = Enum.KeyCode["Number" .. SelectedSlot]
                           PressKey(keyEnum)
                       end
                   end
                   task.wait(0.5)
               end
           end)
       end
   end,
})

CombatTab:CreateSection("Auto Skill")

-- สร้างตารางปุ่ม A-Z
local alphabet = {}
for i = 65, 90 do
    table.insert(alphabet, string.char(i))
end

CombatTab:CreateDropdown({
   Name = "Select Skill Keys (ปุ่มสกิล - เลือกได้หลายปุ่ม)",
   Options = alphabet,
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options)
       SelectedSkills = Options
   end,
})

CombatTab:CreateToggle({
   Name = "Auto Skill Loop",
   CurrentValue = false,
   Callback = function(Value)
       AutoSkillEnabled = Value
       
       if AutoSkillEnabled then
           task.spawn(function()
               while AutoSkillEnabled do
                   -- วนลูปกดทุกปุ่มสกิลที่เลือกไว้
                   for keyName, isSelected in pairs(SelectedSkills) do
                       if isSelected then
                           local keyEnum = Enum.KeyCode[keyName]
                           PressKey(keyEnum)
                           task.wait(0.1) -- หน่วงเวลาเล็กน้อยระหว่างการกดแต่ละปุ่มเพื่อไม่ให้ปุ่มซ้อนกันเกินไป
                       end
                   end
                   task.wait(0.5) -- ระยะเวลาวนรอบการกดสกิลซ้ำซ้อนใหม่ (ปรับได้ตามต้องการ)
               end
           end)
       end
   end,
})

CombatTab:CreateSection("Test Input")

CombatTab:CreateButton({
   Name = "Test Spacebar (ปุ่มทดสอบกระโดด)",
   Callback = function()
       PressKey(Enum.KeyCode.Space)
   end,
})
