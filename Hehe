local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Auto Farm Boss Hub (V3 Fixed)",
   LoadingTitle = "Loading Script...",
   LoadingSubtitle = "by Gemini AI",
   ConfigurationSaving = {
      Enabled = false
   },
   KeySystem = false
})

-- // Variables //
local LocalPlayer = game.Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local VirtualInputManager = game:GetService("VirtualInputManager")

-- รายชื่อโมเดลบอสที่แท้จริงในโฟลเดอร์ ClientEntities
local BossNames = {
    ["Crocodile"] = "Crocodile",
    ["Armored Titan"] = "ArmoredTitan",
    ["Great Ape"] = "GreatApe"
}

local SelectedBosses = {}
local AutoFarmEnabled = false
local SavedPosition = nil

local SelectedSlot = "1"
local AutoEquipEnabled = false

local SelectedSkills = {}
local AutoSkillEnabled = false

LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char
end)

-- ฟังก์ชันช่วยสแกนหาบอสใน ClientEntities โดยละเอียด
local function FindBossInEntities(bossName)
    local clientEntities = workspace:FindFirstChild("ClientEntities")
    
    if clientEntities then
        -- ลองหาแบบระบุชื่อตรงๆ ก่อน
        local boss = clientEntities:FindFirstChild(bossName)
        if boss and boss:FindFirstChild("HumanoidRootPart") then
            return boss
        end
        
        -- ถ้ายังไม่เจอ ให้ลองค้นหาแบบวนลูปเช็คชื่อ (เผื่อชื่อมีเว้นวรรคหรือพิมพ์เล็กพิมพ์ใหญ่ต่างกัน)
        for _, child in pairs(clientEntities:GetChildren()) do
            if child.Name:lower() == bossName:lower() and child:FindFirstChild("HumanoidRootPart") then
                return child
            end
        end
    end
    return nil
end

-- ฟังก์ชันสำหรับบังคับเคลียร์สตรีมและวาร์ป (ช่วยให้ Render ระยะไกลทำงาน)
local function SafeTeleport(targetCFrame)
    if Character and Character:FindFirstChild("HumanoidRootPart") then
        -- แก้ปัญหา StreamingEnabled: บังคับให้โลคอลเพลเยอร์รับรู้พิกัดปลายทางล่วงหน้า
        LocalPlayer:RequestStreamAroundAsync(targetCFrame.Position)
        task.wait(0.05)
        Character.HumanoidRootPart.CFrame = targetCFrame
    end
end

-- ฟังก์ชันกดปุ่ม
local function PressKey(key)
    VirtualInputManager:SendKeyEvent(true, key, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, key, false, game)
end

-- // --- TABS --- //
local MainTab = Window:CreateTab("Main Farm", 4483362458)
local CombatTab = Window:CreateTab("Combat & Skills", 4483362458)

-- // ================= MAIN FARM TAB ================= //

MainTab:CreateSection("Saved Position")

MainTab:CreateButton({
   Name = "Save Current Position (เซฟพิกัดขากลับ)",
   Callback = function()
       if Character and Character:FindFirstChild("HumanoidRootPart") then
           SavedPosition = Character.HumanoidRootPart.CFrame
           Rayfield:Notify({
              Title = "Position Saved!",
              Content = "บันทึกพิกัดเรียบร้อยแล้ว",
              Duration = 3,
              Image = 4483362458,
           })
       end
   end,
})

MainTab:CreateSection("Boss Farming")

MainTab:CreateDropdown({
   Name = "Select Bosses (เลือกบอส)",
   Options = {"Crocodile", "Armored Titan", "Great Ape"},
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options)
       SelectedBosses = Options
   end,
})

MainTab:CreateToggle({
   Name = "Auto Farm Boss",
   CurrentValue = false,
   Callback = function(Value)
       AutoFarmEnabled = Value
       
       if AutoFarmEnabled then
           task.spawn(function()
               while AutoFarmEnabled do
                   local bossFound = false
                   
                   -- ตรวจสอบก่อนว่ามีโฟลเดอร์ ClientEntities ไหม หากระบบยังไม่โหลด ให้ข้ามไปก่อน
                   if workspace:FindFirstChild("ClientEntities") then
                       
                       for displayName, isSelected in pairs(SelectedBosses) do
                           if isSelected then
                               local actualModelName = BossNames[displayName]
                               local bossModel = FindBossInEntities(actualModelName)
                               
                               if bossModel then
                                   bossFound = true
                                   -- วาร์ปไปตรงกลางตัวบอส พร้อมสั่งโหลดแมพรอบๆ ตัวบอส
                                   SafeTeleport(bossModel.HumanoidRootPart.CFrame)
                                   break 
                               end
                           end
                       end
                       
                   end
                   
                   -- ถ้าในโฟลเดอร์ ClientEntities ไม่เจอตัวบอสเลย และเซฟพิกัดไว้ -> วาร์ปกลับจุดเซฟ
                   if not bossFound and SavedPosition then
                       SafeTeleport(SavedPosition)
                   end
                   
                   task.wait(0.4) -- หน่วงเวลาในการสแกนซ้ำเพื่อความเสถียร
               end
           end)
       end
   end,
})

-- // ================= COMBAT & SKILLS TAB ================= //

CombatTab:CreateSection("Auto Equip")

CombatTab:CreateDropdown({
   Name = "Select Slot",
   Options = {"1", "2", "3", "4", "5"},
   CurrentOption = {"1"},
   MultipleOptions = false,
   Callback = function(Option)
       SelectedSlot = Option[1]
   end,
})

CombatTab:CreateToggle({
   Name = "Auto Equip Item",
   CurrentValue = false,
   Callback = function(Value)
       AutoEquipEnabled = Value
       if AutoEquipEnabled then
           task.spawn(function()
               while AutoEquipEnabled do
                   if Character then
                       local holdingItem = Character:FindFirstChildOfClass("Tool")
                       if not holdingItem then
                           local keyEnum = Enum.KeyCode["Number" .. SelectedSlot]
                           PressKey(keyEnum)
                       end
                   end
                   task.wait(0.5)
               end
           end)
       end
   end,
})

CombatTab:CreateSection("Auto Skill")

local alphabet = {}
for i = 65, 90 do table.insert(alphabet, string.char(i)) end

CombatTab:CreateDropdown({
   Name = "Select Skill Keys",
   Options = alphabet,
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options)
       SelectedSkills = Options
   end,
 })

CombatTab:CreateToggle({
   Name = "Auto Skill Loop",
   CurrentValue = false,
   Callback = function(Value)
       AutoSkillEnabled = Value
       if AutoSkillEnabled then
           task.spawn(function()
               while AutoSkillEnabled do
                   for keyName, isSelected in pairs(SelectedSkills) do
                       if isSelected then
                           PressKey(Enum.KeyCode[keyName])
                           task.wait(0.1)
                       end
                   end
                   task.wait(0.5)
               end
           end)
       end
   end,
})

CombatTab:CreateSection("Test Input")

CombatTab:CreateButton({
   Name = "Test Spacebar",
   Callback = function()
       PressKey(Enum.KeyCode.Space)
   end,
})
